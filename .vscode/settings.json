{
    // Keep this file minimal. Do NOT add python.analysis.extraPaths,
    // python.autoComplete.extraPaths, or terminal.integrated.env.windows.PYTHONPATH.
    // Those settings mask packaging bugs by injecting the repo root onto sys.path.
    // The editable install created by `uv sync` is the only thing that should put
    // `mypackage` on the import path.

    "python.analysis.typeCheckingMode": "basic",
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        }
    },
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "editor.rulers": [88],
    "autoDocstring.docstringFormat": "numpy"
}
